{
    "compilerOptions": {
        "target": "es2020",
        "module": "nodenext",
        "declaration": true,
        "outDir": "lib",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
        "moduleResolution": "nodenext",
        "lib": [
            "ESNext",
            "DOM"
        ],
        "types": [],
        "verbatimModuleSyntax": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "test",
        "test",
        "node_modules"
    ]
}