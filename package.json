{
  "name": "@kenjiuno/msgreader-web-ng",
  "description": "Outlook Item File (.msg) reader in JavaScript Npm Module",
  "version": "0.2.0-alpha1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./lib/index.js",
      "types": "./lib/index.d.ts"
    }
  },
  "main": "./lib/index.js",
  "private": false,
  "scripts": {
    "build": "tsc",
    "clean": "rimraf lib",
    "test": "set NODE_ENV=test && npm run mocha test/**/*.ts test2/**/*.ts",
    "prepare": "npm run clean && npm run build && npm run test",
    "mocha": "set NODE_ENV=test && mocha --node-option \"import=tsx\"",
    "dr": "npm publish --dry-run"
  },
  "author": "kenjiuno",
  "repository": "github:HiraokaHyperTools/msgreader-web-ng",
  "license": "Apache-2.0",
  "devDependencies": {
    "@kenjiuno/decompressrtf": "^0.1.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.3.1",
    "@types/temp": "^0.9.4",
    "mocha": "^11.7.5",
    "rimraf": "^6.0.1",
    "temp": "^0.9.4",
    "tsx": "^4.21.0",
    "typedoc": "^0.27.6",
    "typedoc-plugin-rename-defaults": "^0.7.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">= 20.6.0"
  },
  "files": [
    "lib"
  ]
}